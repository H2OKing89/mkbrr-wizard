# mkbrr-wizard sample configuration
# runtime selection:
#   auto  = docker if available (and docker_support:true), else native
#   docker = force docker
#   native = force local mkbrr binary
runtime: auto

docker_support: true
chown: true

unraid:
  # Enable to resolve /mnt/user/* paths to physical /mnt/diskN/* or /mnt/cache* mounts.
  enabled: false
  fuse_root: /mnt/user

  # mount_priority: disk_first|cache_first
  # - disk_first : prefer /mnt/diskN when both disk and cache contain the same relative path
  # - cache_first: prefer /mnt/cache* first
  mount_priority: disk_first

  # split_share_preflight: off|warn|fail
  # - fail: abort before mkbrr when files are split across disks for this path
  # - warn: print warning and continue
  # - off : disable this preflight
  split_share_preflight: fail

  # When runtime=docker and the job path is outside container_data_root (e.g. still /mnt/user/...)
  # split-share preflight cannot safely map/scan the path.
  # split_share_unmapped_docker_path: off|warn|fail
  split_share_unmapped_docker_path: warn

  # Upper bound for files scanned during split-share detection (to avoid huge tree scans)
  split_share_max_entries: 20000
  split_share_follow_symlinks: false

theapp:
  # optional - run mkbrr inside docker as a specific user: "99:100"
  # docker_user: "99:100"

mkbrr:
  binary: mkbrr
  image: ghcr.io/autobrr/mkbrr

paths:
  host_data_root: /mnt/user/data
  container_data_root: /data

  host_output_dir: /mnt/user/data/downloads/torrents/torrentfiles
  container_output_dir: /torrentfiles

  # IMPORTANT for Docker runtime so presets.yaml is visible inside container
  host_config_dir: /mnt/cache/appdata/mkbrr
  container_config_dir: /root/.config/mkbrr

# You can use either an absolute path OR a path relative to host_config_dir
presets_yaml: presets.yaml

# Batch mode:
#   simple   = preset-driven prompts (fast)
#   advanced = includes per-job optional fields
batch:
  mode: simple

ownership:
  uid: 99
  gid: 100

# Notification system — sends alerts via Pushover and/or Discord.
# Both providers can be enabled simultaneously.
# Requires: pip install 'httpx[http2]' (optional dep, gracefully disabled if missing)
# Secrets can use env vars: ${PUSHOVER_APP_TOKEN}, ${DISCORD_WEBHOOK_URL}
# Tip: put secrets in a .env file next to config.yaml (loaded automatically if python-dotenv is installed)
notifications:
  enabled: false
  # summary        = notify after every operation + immediate failure alerts
  # failures_only  = only notify when something fails
  # off            = disable entirely (same as enabled: false)
  policy: summary

  pushover:
    enabled: false
    app_token: ${PUSHOVER_APP_TOKEN}
    user_key: ${PUSHOVER_USER_KEY}
    # Pushover priority: -2 (silent) to 2 (emergency)
    priority: 0
    failure_priority: 1
    # Optional: target specific device name(s)
    device: ""

  discord:
    enabled: false
    webhook_url: ${DISCORD_WEBHOOK_URL}
    username: "mkbrr-wizard"
    avatar_url: ""
    # Embed sidebar colors (hex integers)
    color_success: 0x2ECC71
    color_failure: 0xE74C3C
    color_partial: 0xF39C12

  # HTTP timeout per notification request (seconds)
  timeout_seconds: 10

# Worker auto-tuning — automatically sets --workers based on storage type.
# Detects HDD vs SSD via Unraid path patterns (/mnt/diskN = HDD, /mnt/cache* = SSD)
# with /sys/block rotational flag as a fallback for non-Unraid Linux.
# Use an integer for a specific worker count, or "auto" to let mkbrr decide.
workers:
  hdd: 1        # spinning disks benefit from sequential I/O (1 worker)
  ssd: auto     # SSDs/NVMe handle parallel hashing well (let mkbrr auto-detect)
  default: auto # fallback when storage type can't be determined

# Optional debug/test override - set to false in production if you want safer behaviour
# docker_support: false
